{
  "info": {
    "name": "Gogo Backend API",
    "description": "Postman collection for the customer review and dashboard modules.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "d3a89cda-7de4-4e9a-b8a0-a7350f72a1c1"
  },
  "item": [
    {
      "name": "Signup",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Rafay\",\n  \"email\": \"ali.rafay@example.com\",\n  \"password\": \"secret123\",\n  \"role\": 40\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/signup",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "signup"]
        },
        "description": "Register a new user. role is optional — defaults to 40 (Customer). Roles: 10=Super Admin, 20=Admin, 40=Customer."
      },
      "response": []
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"ali.rafay@example.com\",\n  \"password\": \"secret123\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "login"]
        },
        "description": "Login with email and password. Returns accessToken (7d) and refreshToken (30d)."
      },
      "response": []
    },
    {
      "name": "Refresh Token",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"PUT_REFRESH_TOKEN_HERE\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/refresh-token",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "refresh-token"]
        },
        "description": "Exchange a valid refresh token for a new access token and refresh token."
      },
      "response": []
    },
    {
      "name": "Change Password",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer PUT_ACCESS_TOKEN_HERE" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"secret123\",\n  \"newPassword\": \"newSecret456\",\n  \"confirmPassword\": \"newSecret456\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/change-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "change-password"]
        },
        "description": "Change password for the authenticated user. Requires valid Bearer token."
      },
      "response": []
    },
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            ""
          ]
        },
        "description": "Checks if backend server is running."
      },
      "response": []
    },
    {
      "name": "Create Review",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Ali Rafay\",\n  \"email\": \"ali.rafay@example.com\",\n  \"comment\": \"Great food and service. Will definitely visit again.\",\n  \"ratings\": {\n    \"foodQuality\": 5,\n    \"service\": 4,\n    \"ambiance\": 4,\n    \"environment\": 3\n  }\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/reviews",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reviews"
          ]
        },
        "description": "Submits a customer review with ratings from 0 to 5."
      },
      "response": []
    },
    {
      "name": "Get All Reviews",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/reviews",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reviews"
          ]
        },
        "description": "Fetches all submitted reviews."
      },
      "response": []
    },
    {
      "name": "Get Review By ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/reviews/:id",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reviews",
            ":id"
          ],
          "variable": [
            {
              "key": "id",
              "value": "PUT_REVIEW_ID_HERE"
            }
          ]
        },
        "description": "Fetches a single review by MongoDB review id."
      },
      "response": []
    },
    {
      "name": "Delete Review",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/reviews/:id",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "reviews",
            ":id"
          ],
          "variable": [
            {
              "key": "id",
              "value": "PUT_REVIEW_ID_HERE"
            }
          ]
        },
        "description": "Deletes a single review by MongoDB review id."
      },
      "response": []
    },
    {
      "name": "Get Dashboard Stats",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/dashboard",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "dashboard"
          ]
        },
        "description": "Returns total number of reviews and overall + per-field average ratings."
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000"
    }
  ]
}
